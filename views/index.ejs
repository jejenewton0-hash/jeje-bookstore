<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero">
  <div class="container hero-content">
    <h1>Discover Your Next Great Read</h1>
    <p>Rwanda's premier online bookstore — fiction, education, business and more, delivered to your door.</p>
    <div class="hero-btns">
      <a href="/products" class="btn btn-primary btn-lg">Browse Books</a>
      <a href="/products?category=3" class="btn btn-outline btn-lg">Textbooks</a>
    </div>
  </div>
</section>

<!-- Categories -->
<section class="section">
  <div class="container">
    <h2 class="section-title">Shop by Category</h2>
    <div class="categories-grid">
      <% categories.forEach((cat, i) => { %>
      <a href="/products?category=<%= cat._id %>" class="category-card">
        <i class="fas fa-<%= ['book','newspaper','graduation-cap','child','briefcase'][i] || 'book' %>"></i>
        <span><%= cat.name %></span>
      </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- Featured Books -->
<section class="section bg-light">
  <div class="container">
    <h2 class="section-title">Featured Books</h2>
    <div class="products-grid">
      <% featured.forEach(product => { %>
      <div class="product-card">
        <a href="/products/<%= product._id %>">
          <div class="product-img-wrap">
            <img src="<%= product.image %>" alt="<%= product.name %>" onerror="this.src='/images/book-placeholder.png'" />
          </div>
          <div class="product-info">
            <span class="product-category"><%= product.category ? product.category.name : '' %></span>
            <h3 class="product-name"><%= product.name %></h3>
            <p class="product-author">by <%= product.author %></p>
            <div class="product-footer">
              <span class="product-price"><%= Number(product.price).toLocaleString() %> RWF</span>
              <% if (product.stock > 0) { %>
                <span class="badge badge-success">In Stock</span>
              <% } else { %>
                <span class="badge badge-danger">Out of Stock</span>
              <% } %>
            </div>
          </div>
        </a>
        <button class="btn btn-primary btn-block add-to-cart-btn"
          data-id="<%= product._id %>" <%= product.stock === 0 ? 'disabled' : '' %>>
          <i class="fas fa-cart-plus"></i> Add to Cart
        </button>
      </div>
      <% }) %>
    </div>
    <div class="text-center mt-2">
      <a href="/products" class="btn btn-outline btn-lg">View All Books</a>
    </div>
  </div>
</section>

<!-- Why Us -->
<section class="section">
  <div class="container">
    <h2 class="section-title">Why Choose JEJE</h2>
    <div class="features-grid">
      <div class="feature-card">
        <i class="fas fa-truck"></i>
        <h3>Fast Delivery</h3>
        <p>Nationwide delivery across Rwanda within 2–3 business days.</p>
      </div>
      <div class="feature-card">
        <i class="fas fa-shield-alt"></i>
        <h3>Secure Payments</h3>
        <p>Safe and secure checkout with multiple payment options.</p>
      </div>
      <div class="feature-card">
        <i class="fas fa-undo"></i>
        <h3>Easy Returns</h3>
        <p>Hassle-free returns within 7 days of purchase.</p>
      </div>
      <div class="feature-card">
        <i class="fas fa-headset"></i>
        <h3>24/7 Support</h3>
        <p>Our team is always ready to help you find the right book.</p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
