<%- include('../partials/header') %>

<section class="section">
  <div class="container">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
      <h1 class="page-title" style="margin:0"><i class="fas fa-list-alt"></i> Manage Orders</h1>
      <a href="/admin" class="btn btn-outline btn-sm">← Dashboard</a>
    </div>

    <div style="overflow-x:auto">
      <table class="cart-table">
        <thead>
          <tr><th>Order ID</th><th>Customer</th><th>Email</th><th>Phone</th><th>Total</th><th>Payment</th><th>Status</th><th>Date</th><th>Update</th></tr>
        </thead>
        <tbody>
          <% orders.forEach(o => { %>
          <tr>
            <td><strong>#<%= o._id.toString().slice(-5).toUpperCase() %></strong></td>
            <td><%= o.customerName %></td>
            <td><%= o.customerEmail %></td>
            <td><%= o.customerPhone %></td>
            <td><%= Number(o.total).toLocaleString() %> RWF</td>
            <td><%= o.paymentMethod || 'cod' %></td>
            <td>
              <span class="badge <%= o.status === 'delivered' ? 'badge-success' : o.status === 'cancelled' ? 'badge-danger' : 'badge-warning' %>">
                <%= o.status.toUpperCase() %>
              </span>
            </td>
            <td><%= new Date(o.createdAt).toLocaleDateString() %></td>
            <td>
              <form action="/admin/orders/<%= o._id %>/status" method="POST" style="display:flex;gap:0.4rem">
                <select name="status" style="padding:0.3rem;border:1px solid #dee2e6;border-radius:6px;font-size:0.85rem">
                  <option value="pending" <%= o.status==='pending'?'selected':'' %>>Pending</option>
                  <option value="processing" <%= o.status==='processing'?'selected':'' %>>Processing</option>
                  <option value="shipped" <%= o.status==='shipped'?'selected':'' %>>Shipped</option>
                  <option value="delivered" <%= o.status==='delivered'?'selected':'' %>>Delivered</option>
                  <option value="cancelled" <%= o.status==='cancelled'?'selected':'' %>>Cancelled</option>
                </select>
                <button type="submit" class="btn btn-primary btn-sm">Save</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
