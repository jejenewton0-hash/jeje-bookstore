<%- include('partials/header') %>

<section class="section">
  <div class="container">
    <h1 class="page-title">Shopping Cart</h1>
    <div id="cartContent">
      <div class="loading"><i class="fas fa-spinner fa-spin"></i> Loading cart...</div>
    </div>
  </div>
</section>

<script>
async function loadCart() {
  const res = await fetch('/api/cart');
  const data = await res.json();
  const el = document.getElementById('cartContent');

  if (!data.items || data.items.length === 0) {
    el.innerHTML = `
      <div class="empty-state">
        <i class="fas fa-shopping-cart"></i>
        <h3>Your cart is empty</h3>
        <p>Browse our collection and add some books!</p>
        <a href="/products" class="btn btn-primary">Browse Books</a>
      </div>`;
    return;
  }

  let rows = data.items.map(item => `
    <tr>
      <td>
        <div class="cart-product">
          <img src="${item.image}" alt="${item.name}" onerror="this.src='/images/book-placeholder.png'" />
          <div>
            <a href="/products/${item._id}">${item.name}</a>
            <small>by ${item.author}</small>
          </div>
        </div>
      </td>
      <td>${Number(item.price).toLocaleString()} RWF</td>
      <td>
        <div class="qty-control">
          <button onclick="updateQty('${item.productId}', ${item.quantity - 1})">-</button>
          <input type="number" value="${item.quantity}" min="1"
            onchange="updateQty('${item.productId}', this.value)" style="width:50px;text-align:center" />
          <button onclick="updateQty('${item.productId}', ${item.quantity + 1})">+</button>
        </div>
      </td>
      <td>${Number(item.price * item.quantity).toLocaleString()} RWF</td>
      <td>
        <button class="btn btn-danger btn-sm" onclick="removeItem('${item.productId}')">
          <i class="fas fa-trash"></i>
        </button>
      </td>
    </tr>`).join('');

  el.innerHTML = `
    <div class="cart-layout">
      <div class="cart-table-wrap">
        <table class="cart-table">
          <thead><tr><th>Book</th><th>Price</th><th>Quantity</th><th>Subtotal</th><th></th></tr></thead>
          <tbody>${rows}</tbody>
        </table>
        <button class="btn btn-outline btn-sm" onclick="clearCart()">
          <i class="fas fa-trash"></i> Clear Cart
        </button>
      </div>
      <div class="cart-summary">
        <h3>Order Summary</h3>
        <div class="summary-row"><span>Subtotal</span><span>${Number(data.total).toLocaleString()} RWF</span></div>
        <div class="summary-row"><span>Delivery</span><span>Free</span></div>
        <div class="summary-row total"><span>Total</span><span>${Number(data.total).toLocaleString()} RWF</span></div>
        <a href="/checkout" class="btn btn-primary btn-block btn-lg">Proceed to Checkout</a>
        <a href="/products" class="btn btn-outline btn-block mt-1">Continue Shopping</a>
      </div>
    </div>`;
}

async function updateQty(productId, quantity) {
  if (quantity < 1) return removeItem(productId);
  await fetch('/api/cart/update', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ productId, quantity: parseInt(quantity) })
  });
  loadCart();
  updateCartBadge();
}

async function removeItem(productId) {
  await fetch(`/api/cart/remove/${productId}`, { method: 'DELETE' });
  loadCart();
  updateCartBadge();
}

async function clearCart() {
  if (!confirm('Clear all items from cart?')) return;
  await fetch('/api/cart/clear', { method: 'DELETE' });
  loadCart();
  updateCartBadge();
}

loadCart();
</script>
<%- include('partials/footer') %>
